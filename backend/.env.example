# Copy to backend/.env to override defaults.

# Database connection string. Defaults to a local SQLite file (backend/prelegal.db).
# To use Postgres later, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/prelegal
# DATABASE_URL=sqlite:///./prelegal.db

# Comma/JSON list of allowed CORS origins (the frontend dev server).
# CORS_ORIGINS=["http://localhost:3000"]
