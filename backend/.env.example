# Copy to backend/.env to override defaults.

# Database connection string. Defaults to a local SQLite file (backend/prelegal.db).
# To use Postgres later, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/prelegal
# DATABASE_URL=sqlite:///./prelegal.db

# Comma/JSON list of allowed CORS origins (the frontend dev server).
# CORS_ORIGINS=["http://localhost:3000"]

# OpenRouter API key for the AI chat (PL-5). Required for the /api/chat endpoint.
# Get one at https://openrouter.ai/keys.
OPENROUTER_API_KEY=

# Optional overrides for the chat model, OpenRouter base URL, and output cap.
# CHAT_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# CHAT_MAX_TOKENS=4096

# Authentication (PL-7). Set a strong, random JWT_SECRET in any real deployment;
# the built-in default is only meant for local preview.
# JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRE_MINUTES=10080

# The temporary database is dropped and recreated on startup (data does not
# survive a restart). Set to false to keep data across restarts.
# RESET_DB_ON_STARTUP=true
